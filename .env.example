# ─── 服务配置 ────────────────────────────────────────────────
# 监听地址（0.0.0.0 = 所有网卡，127.0.0.1 = 仅本地）
HOST=0.0.0.0

# 端口
PORT=8900

# 调试模式（true/false）
DEBUG=false

# ─── IP 白名单 ──────────────────────────────────────────────
# 允许访问的 IP/CIDR 列表，逗号分隔
# 默认：仅本地访问
# 生产环境示例：127.0.0.1,::1,10.0.0.5,172.16.0.0/12
# Moread 服务器：添加 Moread 后端所在服务器 IP
ALLOWED_IPS=127.0.0.1,::1

# ─── CORS ───────────────────────────────────────────────────
# 允许的跨域来源，逗号分隔（* = 全部）
CORS_ORIGINS=*
